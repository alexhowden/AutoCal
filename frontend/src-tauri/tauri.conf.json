{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoCal",
  "version": "0.1.0",
  "identifier": "dev.autocal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5177",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AutoCal",
        "width": 1140,
        "height": 740,
        "minWidth": 920,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#060609",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
